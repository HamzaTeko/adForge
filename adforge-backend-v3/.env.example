# ═══════════════════════════════════════════════════════════════
# AdForge Backend — Environment Variables
# Copy this file: cp .env.example .env  then fill in real values
# NEVER commit .env to git — add it to .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Supabase (get from supabase.com → Project Settings → API) ─
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic API Key (server-side AI for copy/refine routes) ──
# Get at: console.anthropic.com → API Keys
# Powers: /api/copy/generate and /api/copy/refine endpoints
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI API Key (copy generation + DALL-E fallback) ────────
# Get at: platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-...

# ── fal.ai API Key (image + video generation) ─────────────────
# Get at: fal.ai → Dashboard → API Keys → Create new key
# Powers: FLUX.1 image generation + Kling 3.0 video generation
# One key covers ALL fal.ai models (1000+ models)
FAL_API_KEY=your_fal_api_key

# ── Meta App (get from developers.facebook.com) ───────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ID=your_facebook_page_id

# ── URLs ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
# Production:
# FRONTEND_URL=https://adforge.vercel.app
# BACKEND_URL=https://adforge-api.onrender.com

PORT=3001
NODE_ENV=development


# Anthropic Claude (AI assistant)
ANTHROPIC_API_KEY=sk-ant-api03-...
